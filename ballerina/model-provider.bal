import ballerina/ai;
import ballerina/ai.observe;
import ballerina/http;
import ballerina/jballerina.java;
import ballerina/log;
import ballerinax/azure.openai.responses as responses;

# `OpenAiModelProvider` is a client class that provides an interface for interacting with Azure-hosted OpenAI
# language models using the **legacy Azure OpenAI API surface** (deployment-scoped routes with a date-based
# `api-version`, e.g. `2024-08-01-preview`).
#
# The public API of this class is kept backward compatible with previous releases. In addition, this class now
# transparently tries the Azure OpenAI **Responses API** first (`POST {serviceUrl}/openai/responses?api-version=...`)
# and, if the targeted model or `api-version` does not support it, falls back to the
# **Chat Completions API** (`POST {serviceUrl}/openai/deployments/{deploymentId}/chat/completions?api-version=...`).
#
# > **Note:** For new applications targeting the Azure OpenAI v1 (GA) API surface, prefer `OpenAiModelProviderV2`.
public isolated client class OpenAiModelProvider {
    *ai:ModelProvider;
    private final http:Client httpClient;
    private final string apiKey;
    private final string deploymentId;
    private final string apiVersion;
    private final decimal temperature;
    private final int maxTokens;
    private final (responses:OpenAI\.Reasoning & readonly)? reasoning;
    private boolean responsesApiUnsupported = false;

    # Initializes the Azure OpenAI model with the given connection configuration and model configuration.
    #
    # + serviceUrl - The base URL of the Azure OpenAI API endpoint (e.g. `https://<resource>.openai.azure.com`)
    # + apiKey - The Azure OpenAI API key
    # + deploymentId - The deployment identifier for the specific model deployment in Azure
    # + apiVersion - The Azure OpenAI API version (e.g. `"2024-08-01-preview"`)
    # + maxTokens - The upper limit for the number of tokens in the response generated by the model
    # + temperature - The temperature for controlling randomness in the model's output.
    #               Higher values (e.g., 0.8) make output more random, while lower values (e.g., 0.2) make it more
    #               focused and deterministic.
    # + reasoningEffort - Reasoning effort level for reasoning models. This is only applied on the Responses API path
    #                   and is ignored when falling back to the Chat Completions API.
    # + connectionConfig - Additional HTTP connection configuration
    # + return - `nil` on successful initialization; otherwise, returns an `ai:Error`
    public isolated function init(@display {label: "Service URL"} string serviceUrl,
            @display {label: "API Key"} string apiKey,
            @display {label: "Deployment ID"} string deploymentId,
            @display {label: "API Version"} string apiVersion,
            @display {label: "Maximum Tokens"} int maxTokens = DEFAULT_MAX_TOKEN_COUNT,
            @display {label: "Temperature"} decimal temperature = DEFAULT_TEMPERATURE,
            @display {label: "Reasoning Effort"} responses:OpenAI\.Reasoning? reasoningEffort = (),
            @display {label: "Connection Configuration"} *ConnectionConfig connectionConfig) returns ai:Error? {

        string normalizedUrl = serviceUrl.endsWith("/") ? serviceUrl.substring(0, serviceUrl.length() - 1) : serviceUrl;

        http:ClientConfiguration httpClientConfig = {
            httpVersion: connectionConfig.httpVersion,
            http1Settings: connectionConfig.http1Settings ?: {},
            http2Settings: connectionConfig.http2Settings ?: {},
            timeout: connectionConfig.timeout,
            forwarded: connectionConfig.forwarded,
            poolConfig: connectionConfig.poolConfig,
            cache: connectionConfig.cache ?: {},
            compression: connectionConfig.compression,
            circuitBreaker: connectionConfig.circuitBreaker,
            retryConfig: connectionConfig.retryConfig,
            responseLimits: connectionConfig.responseLimits ?: {},
            secureSocket: connectionConfig.secureSocket,
            proxy: connectionConfig.proxy,
            validation: connectionConfig.validation
        };

        http:Client|error httpClient = new (normalizedUrl, httpClientConfig);
        if httpClient is error {
            return error ai:Error("Failed to initialize Azure OpenAI HTTP client", httpClient);
        }
        self.httpClient = httpClient;
        self.apiKey = apiKey;
        self.deploymentId = deploymentId;
        self.apiVersion = apiVersion;
        self.temperature = temperature;
        self.maxTokens = maxTokens;
        self.reasoning = reasoningEffort.cloneReadOnly();
    }

    # Sends a chat request to the OpenAI model with the given messages and tools.
    #
    # + messages - List of chat messages or a user message
    # + tools - Tool definitions to be used for the tool call
    # + stop - Stop sequence to stop the completion
    # + return - Function to be called, chat response or an error in-case of failures
    isolated remote function chat(ai:ChatMessage[]|ai:ChatUserMessage messages,
            ai:ChatCompletionFunctions[] tools = [], string? stop = ())
            returns ai:ChatAssistantMessage|ai:Error {
        boolean tryResponses;
        lock {
            tryResponses = !self.responsesApiUnsupported;
        }

        if tryResponses {
            ai:ChatAssistantMessage|ai:Error result = self.chatViaResponses(messages, tools, stop);
            if result is ai:Error && isResponsesApiUnsupportedError(result) {
                lock {
                    self.responsesApiUnsupported = true;
                }
                log:printWarn("Model does not support the Azure OpenAI Responses API, falling back to Chat Completions API");
            } else {
                return result;
            }
        }

        return self.chatViaChatCompletions(messages, tools, stop);
    }

    # Sends a chat request to the model and generates a value that belongs to the type
    # corresponding to the type descriptor argument.
    #
    # + prompt - The prompt to use in the chat messages
    # + td - Type descriptor specifying the expected return type format
    # + return - Generates a value that belongs to the type, or an error if generation fails
    isolated remote function generate(ai:Prompt prompt, @display {label: "Expected type"} typedesc<anydata> td = <>)
                returns td|ai:Error = @java:Method {
        'class: "io.ballerina.lib.ai.azure.Generator"
    } external;

    // ===== Chat Completions API path =====

    private isolated function chatViaChatCompletions(ai:ChatMessage[]|ai:ChatUserMessage messages,
            ai:ChatCompletionFunctions[] tools, string? stop) returns ai:ChatAssistantMessage|ai:Error {
        observe:ChatSpan span = observe:createChatSpan(self.deploymentId);
        span.addProvider("azure.ai.openai");
        span.addOutputType(observe:TEXT);
        if stop is string {
            span.addStopSequence(stop);
        }
        span.addTemperature(self.temperature);

        json|ai:Error jsonMsg = convertMessageToJson(messages);
        if jsonMsg is ai:Error {
            ai:Error err = error("Error while transforming input", jsonMsg);
            span.close(err);
            return err;
        }
        span.addInputMessages(jsonMsg);

        json[]|ai:Error requestMessages = mapToLegacyChatCompletionRequestMessages(messages);
        if requestMessages is ai:Error {
            ai:Error err = error("Error while preparing chat completion request messages", requestMessages);
            span.close(err);
            return err;
        }

        map<json> request = {
            messages: requestMessages,
            temperature: self.temperature,
            max_tokens: self.maxTokens
        };
        if stop is string {
            request["stop"] = stop;
        }
        if tools.length() > 0 {
            request["functions"] = tools.toJson();
            span.addTools(tools);
        }

        string path = string `/openai/deployments/${self.deploymentId}/chat/completions?api-version=${self.apiVersion}`;
        json|error response = self.httpClient->post(path, request, headers = {"api-key": self.apiKey});
        if response is error {
            ai:Error err = error ai:LlmConnectionError("Error while connecting to the model", response);
            log:printError("Error response received from the Chat Completions API", err);
            span.close(err);
            return err;
        }

        LegacyChatCompletionResponse|error typedResponse = response.cloneWithType();
        if typedResponse is error {
            ai:Error err = error ai:LlmInvalidResponseError("Error while parsing the model response", typedResponse);
            span.close(err);
            return err;
        }

        LegacyChatChoice[] choices = typedResponse.choices ?: [];
        if choices.length() == 0 {
            ai:Error err = error ai:LlmInvalidResponseError("Empty response from the model when using function call API");
            span.close(err);
            return err;
        }

        string? responseId = typedResponse.id;
        if responseId is string {
            span.addResponseId(responseId);
        }
        LegacyChatUsage? usage = typedResponse.usage;
        if usage is LegacyChatUsage {
            int? inputTokens = usage.prompt_tokens;
            if inputTokens is int {
                span.addInputTokenCount(inputTokens);
            }
            int? outputTokens = usage.completion_tokens;
            if outputTokens is int {
                span.addOutputTokenCount(outputTokens);
            }
        }
        string? finishReason = choices[0].finish_reason;
        if finishReason is string {
            span.addFinishReason(finishReason);
        }

        LegacyChatResponseMessage? message = choices[0].message;
        ai:ChatAssistantMessage chatAssistantMessage = {role: ai:ASSISTANT, content: message?.content};
        LegacyFunctionCall? functionCall = message?.function_call;
        if functionCall is () {
            span.addOutputMessages(chatAssistantMessage);
            span.close();
            return chatAssistantMessage;
        }

        ai:FunctionCall|ai:Error toolCall = mapToFunctionCall(functionCall);
        if toolCall is ai:Error {
            span.close(toolCall);
            return toolCall;
        }
        chatAssistantMessage.toolCalls = [toolCall];
        span.addOutputMessages(chatAssistantMessage);
        span.close();
        return chatAssistantMessage;
    }

    // ===== Responses API path =====

    private isolated function chatViaResponses(ai:ChatMessage[]|ai:ChatUserMessage messages,
            ai:ChatCompletionFunctions[] functionToolDefs, string? stop)
            returns ai:ChatAssistantMessage|ai:Error {
        observe:ChatSpan span = observe:createChatSpan(self.deploymentId);
        span.addProvider("azure.ai.openai");
        if stop is string {
            span.addStopSequence(stop);
        }
        span.addTemperature(self.temperature);

        json|ai:Error inputMessage = convertMessageToJson(messages);
        if inputMessage is json {
            span.addInputMessages(inputMessage);
        }

        [responses:OpenAI\.InputParam, string?]|ai:Error responseInput = convertToResponsesInput(messages);
        if responseInput is ai:Error {
            ai:Error err = error("Error while transforming input for the Responses API", responseInput);
            span.close(err);
            return err;
        }
        [responses:OpenAI\.InputParam, string?] [inputItems, instructions] = responseInput;

        responses:OpenAI\.CreateResponse request = {
            model: self.deploymentId,
            input: inputItems,
            max_output_tokens: self.maxTokens,
            temperature: self.temperature,
            store: false
        };
        if instructions is string {
            request.instructions = instructions;
        }
        if stop is string {
            log:printWarn("The 'stop' parameter is not supported by the Responses API and will be ignored.",
                model = self.deploymentId);
        }

        responses:OpenAI\.Tool[] allTools = [];
        if functionToolDefs.length() > 0 {
            responses:OpenAI\.Tool[]|error functionTools = convertToResponsesTools(functionToolDefs);
            if functionTools is error {
                ai:Error err = error("Error while adding tools into the Responses API request", functionTools);
                span.close(err);
                return err;
            }
            allTools.push(...functionTools);
            span.addTools(functionToolDefs);
        }
        if allTools.length() > 0 {
            request.tools = allTools;
        }
        if self.reasoning is responses:OpenAI\.Reasoning {
            request.reasoning = self.reasoning;
        }

        string path = string `/openai/responses?api-version=${self.apiVersion}`;
        json|error response = self.httpClient->post(path, request.toJson(), headers = {"api-key": self.apiKey});
        if response is error {
            ai:Error err = error ai:LlmConnectionError("Error while connecting to the model", response);
            log:printError("Error response received from the Responses API", err);
            span.close(err);
            return err;
        }

        responses:inline_response_200_5|error typedResponse = response.cloneWithType();
        if typedResponse is error {
            ai:Error err = error ai:LlmInvalidResponseError("Error while parsing the Responses API response", typedResponse);
            span.close(err);
            return err;
        }

        string? status = typedResponse?.status;
        if status == "failed" {
            string errorMsg = "Response generation failed";
            anydata responseError = typedResponse.'error;
            if responseError != () {
                errorMsg = responseError.toString();
            }
            ai:Error err = error ai:LlmConnectionError(errorMsg);
            span.close(err);
            return err;
        }
        if status == "incomplete" {
            string errorMsg = "Response generation incomplete";
            anydata details = typedResponse.incomplete_details;
            if details != () {
                errorMsg = string `Response incomplete: ${details.toString()}`;
            }
            ai:Error err = error ai:LlmInvalidResponseError(errorMsg);
            span.close(err);
            return err;
        }
        if status == "cancelled" {
            ai:Error err = error ai:LlmConnectionError("Response generation was cancelled");
            span.close(err);
            return err;
        }
        if status == "in_progress" || status == "queued" {
            ai:Error err = error ai:LlmConnectionError(
                string `Response is still ${status}; use background mode with polling to handle async responses`);
            span.close(err);
            return err;
        }

        span.addResponseId(typedResponse.id);
        responses:OpenAI\.ResponseUsage? usage = typedResponse.usage;
        if usage is responses:OpenAI\.ResponseUsage {
            span.addInputTokenCount(usage.input_tokens);
            span.addOutputTokenCount(usage.output_tokens);
        }
        span.addFinishReason(status ?: "completed");

        ai:ChatAssistantMessage|ai:Error message = convertResponsesOutputToAssistantMessage(typedResponse);
        if message is ai:Error {
            span.close(message);
            return message;
        }
        span.addOutputMessages(message);
        span.addOutputType(observe:TEXT);
        span.close();
        return message;
    }
}

// ===== Shared helpers for the legacy provider =====

# Determines whether the given error indicates that the targeted model/`api-version` does not support the
# Azure OpenAI Responses API (so a fall-back to Chat Completions is warranted).
#
# + err - The error returned from the Responses API call
# + return - `true` if the error indicates an unsupported Responses API; `false` otherwise
isolated function isResponsesApiUnsupportedError(ai:Error err) returns boolean {
    if isResponsesUnsupportedMessage(err.toString().toLowerAscii()) {
        return true;
    }
    error? cause = err.cause();
    if cause is error {
        if isResponsesUnsupportedMessage(cause.toString().toLowerAscii()) {
            return true;
        }
        // HTTP client errors carry the response body (which holds the Azure error code) in the error detail.
        return isResponsesUnsupportedMessage(cause.detail().toString().toLowerAscii());
    }
    return false;
}

isolated function isResponsesUnsupportedMessage(string message) returns boolean =>
    message.includes("model_not_found")
        || message.includes("operationnotsupported")
        || message.includes("the api deployment for this resource does not exist")
        || message.includes("unknown api version")
        || message.includes("invalid api version")
        || message.includes("not supported")
        || message.includes("404");

# Maps the chat messages to the legacy Azure OpenAI Chat Completions request message format
# (uses the deprecated `function_call` field for assistant tool calls).
#
# + messages - The chat messages to map
# + return - The mapped messages as a JSON array, or an `ai:Error`
isolated function mapToLegacyChatCompletionRequestMessages(ai:ChatMessage[]|ai:ChatUserMessage messages)
        returns json[]|ai:Error {
    json[] result = [];
    if messages is ai:ChatUserMessage {
        result.push(check mapToLegacyAzureChatMessage(messages));
        return result;
    }
    foreach ai:ChatMessage message in messages {
        if message is ai:ChatUserMessage|ai:ChatSystemMessage {
            result.push(check mapToLegacyAzureChatMessage(message));
        } else if message is ai:ChatAssistantMessage {
            map<json> assistantMessage = {role: ai:ASSISTANT};
            ai:FunctionCall[]? toolCalls = message.toolCalls;
            if toolCalls is ai:FunctionCall[] && toolCalls.length() > 0 {
                assistantMessage["function_call"] = {
                    name: toolCalls[0].name,
                    arguments: (toolCalls[0].arguments ?: {}).toJsonString()
                };
            }
            string? content = message?.content;
            if content is string {
                assistantMessage["content"] = content;
            }
            result.push(assistantMessage);
        } else if message is ai:ChatFunctionMessage {
            result.push(message.toJson());
        }
    }
    return result;
}

isolated function mapToLegacyAzureChatMessage(ai:ChatUserMessage|ai:ChatSystemMessage message) returns json|ai:Error {
    if message is ai:ChatSystemMessage {
        return {
            role: ai:SYSTEM,
            content: check getChatMessageStringContent(message.content),
            name: message.name
        };
    }
    return {
        role: ai:USER,
        content: check getChatMessageStringContent(message.content),
        name: message.name
    };
}

isolated function mapToFunctionCall(LegacyFunctionCall functionCall) returns ai:FunctionCall|ai:Error {
    do {
        json jsonArgs = check functionCall.arguments.fromJsonString();
        map<json>? arguments = check jsonArgs.cloneWithType();
        return {name: functionCall.name, arguments};
    } on fail error e {
        return error ai:LlmInvalidResponseError("Invalid or malformed arguments received in function call response.", e);
    }
}

// ===== Minimal record types for the legacy Chat Completions response =====

type LegacyFunctionCall record {|
    string name;
    string arguments;
|};

type LegacyChatResponseMessage record {
    string? content?;
    LegacyFunctionCall function_call?;
};

type LegacyChatChoice record {
    LegacyChatResponseMessage message?;
    string finish_reason?;
    int index?;
};

type LegacyChatUsage record {
    int prompt_tokens?;
    int completion_tokens?;
    int total_tokens?;
};

type LegacyChatCompletionResponse record {
    string id?;
    LegacyChatChoice[] choices?;
    LegacyChatUsage usage?;
};
